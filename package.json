{
  "name": "agentvendi",
  "version": "1.0.0",
  "description": "AI Agent Vending Machine — Create, configure, and export AI agents",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/index.js\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:db": "vitest run tests/db.test.js",
    "test:benchmark": "vitest run tests/benchmarks.test.js",
    "migrate": "node scripts/migrate.js up",
    "migrate:rollback": "node scripts/migrate.js rollback",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "isolated-vm": "^6.1.2",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "ollama": "^0.5.0",
    "pg": "^8.20.0",
    "quickjs-emscripten": "^0.32.0",
    "uuid": "^10.0.0",
    "vm2": "^3.10.5",
    "winston": "^3.19.0",
    "ws": "^8.20.0",
    "zod": "^3.23.0",
    "zui": "^3.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "concurrently": "^9.1.0",
    "jscodeshift": "^17.3.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  },
  "license": "MIT"
}
